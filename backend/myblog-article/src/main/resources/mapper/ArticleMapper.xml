<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.yry.blog.myblogarticle.mapper.ArticleMapper">
    <!-- 定义结果集映射 -->
    <resultMap id="ArticleVOMap" type="com.yry.blog.myblogarticle.vo.ArticleVO">
        <!-- 文章表字段映射 -->
        <id property="id" column="id"/>
        <result property="authId" column="auth_id"/>
        <result property="authName" column="auth_name"/>
        <result property="authAvatar" column="auth_avatar"/>
        <result property="coverUrl" column="cover_url"/>
        <result property="title" column="title"/>
        <result property="summary" column="summary"/>
        <result property="readCount" column="read_count"/>
        <result property="likeCount" column="like_count"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- 原有：基础分页查询（带动态条件） -->
    <select id="selectArticlePage" resultMap="ArticleVOMap">
        SELECT
        a.*,
        u.nickname AS auth_name,
        u.avatar_url AS auth_avatar
        FROM
        articles a
        LEFT JOIN
        users u ON a.auth_id = u.id
        <where>
            a.is_deleted = 0
            AND a.status != 0
            <!-- 动态条件：标题 -->
            <if test="query.title != null and query.title != ''">
                AND a.title LIKE CONCAT('%', #{query.title}, '%')
            </if>
            <!-- 动态条件：状态 -->
            <if test="query.status != null">
                AND a.status = #{query.status}
            </if>
            <!-- 动态条件：作者昵称 -->
            <if test="query.authorName != null and query.authorName != ''">
                AND u.nickname LIKE CONCAT('%', #{query.authorName}, '%')
            </if>
        </where>
        ORDER BY a.created_at
        <choose>
            <when test="query.sortOrder != null and query.sortOrder == 0">
                ASC
            </when>
            <otherwise> <!-- 默认或 sortOrder == 1 -->
                DESC
            </otherwise>
        </choose>
    </select>
</mapper>